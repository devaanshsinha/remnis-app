{
  "manifest_version": 3,
  "name": "Remnis Browser Adapter",
  "version": "0.1.0",
  "description": "Sends active tab context to local Remnis sidecar.",
  "permissions": [
    "tabs"
  ],
  "host_permissions": [
    "http://127.0.0.1:8765/*",
    "http://localhost:8765/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Remnis Adapter"
  }
}
