{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Remnis",
  "version": "0.1.0",
  "identifier": "com.remnis.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "settings",
        "title": "Remnis",
        "create": false,
        "width": 900,
        "height": 620,
        "center": true,
        "resizable": true
      },
      {
        "label": "search",
        "title": "Remnis Search",
        "width": 780,
        "height": 128,
        "center": true,
        "visible": false,
        "transparent": true,
        "decorations": false,
        "shadow": false,
        "resizable": false,
        "maximizable": false,
        "minimizable": false,
        "alwaysOnTop": true,
        "visibleOnAllWorkspaces": true,
        "acceptFirstMouse": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
