{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Remnis",
  "version": "0.1.0",
  "identifier": "com.remnis.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Remnis",
        "width": 900,
        "height": 620,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
